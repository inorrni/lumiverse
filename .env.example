# ─────────────────────────────────────────────────────────────
# Lumiverse 환경변수 예시 파일
#
# 사용법:
#   1) 이 파일을 복사해서 `.env.local` 을 만든다.
#        cp .env.example .env.local
#   2) `.env.local` 에 본인 값을 채운다.
#   3) `.env.local` 은 .gitignore 에 의해 커밋되지 않는다. (절대 커밋 금지)
#
# ⚠️ Vite 에서 `VITE_` 로 시작하는 변수는 빌드 시 클라이언트(브라우저) 코드에
#    그대로 들어가 노출된다. 따라서 LLM API 키 같은 비밀값은 절대 `VITE_` 로
#    넣지 말 것. LLM 키는 백엔드(FastAPI) 서버 환경변수로만 보관한다.
# ─────────────────────────────────────────────────────────────

# ───────────── 프론트엔드 (Vite · 브라우저에 노출됨) ─────────────

# 백엔드 API 서버 주소 (FastAPI — 로컬 개발 / 배포 시 Render URL)
VITE_API_BASE_URL=http://localhost:8000

# Supabase 프로젝트 (anon key 는 공개용 — RLS 로 보호되므로 노출 OK)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ───────────── 백엔드 키 (참고용 — 별도 리포에서 관리) ─────────────
# 아래 비밀값은 이 프론트엔드 리포가 아니라 백엔드(FastAPI) 리포의
# 서버 환경변수로 설정한다. 여기엔 어떤 키가 필요한지 참고용으로만 기재.
#
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=        # 서버 전용 비밀키 (절대 클라이언트 노출 금지)
# GROQ_API_KEY=                     # 메인 LLM (Llama 3.3 70B, 무료)
# SOLAR_API_KEY=                    # 이달까지 (Upstage · 6월말 만료)

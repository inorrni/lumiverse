# ─────────────────────────────────────────────────────────────
# Lumiverse 환경변수 예시 파일
#
# 사용법:
#   1) 이 파일을 복사해서 `.env.local` 을 만든다.
#        cp .env.example .env.local
#   2) `.env.local` 에 본인 값을 채운다.
#   3) `.env.local` 은 .gitignore 에 의해 커밋되지 않는다. (절대 커밋 금지)
#
# ⚠️ Vite 에서 `VITE_` 로 시작하는 변수는 빌드 시 클라이언트(브라우저) 코드에
#    그대로 들어가 노출된다. 따라서 LLM API 키·service_role 키 같은 비밀값은 절대
#    `VITE_` 로 넣지 말 것. 그 키들은 Supabase Edge Function secrets 로만 보관한다.
# ─────────────────────────────────────────────────────────────

# ───────────── 프론트엔드 (Vite · 브라우저에 노출됨) ─────────────

# Supabase 프로젝트 (anon key 는 공개용 — RLS 로 보호되므로 노출 OK)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ───────────── Edge Function secrets (참고용 — 코드/번들에 넣지 말 것) ─────────────
# 아래 값은 프론트엔드가 아니라 Supabase Edge Function 환경에 설정한다.
#   supabase secrets set LLM_API_KEY=... LLM_BASE_URL=... LLM_MODEL=...
# (SUPABASE_URL / SUPABASE_ANON_KEY 는 Edge Function 런타임이 자동 주입)
#
# LLM_API_KEY=                      # LLM 공급자 키 (Solar/Groq)
# LLM_BASE_URL=                     # 기본 https://api.upstage.ai/v1 (Groq: https://api.groq.com/openai/v1)
# LLM_MODEL=                        # 기본 solar-pro2 (json_object 지원) · Groq: llama-3.3-70b-versatile
# SUPABASE_SERVICE_ROLE_KEY=        # 서버 전용 비밀키 (절대 클라이언트 노출 금지)
